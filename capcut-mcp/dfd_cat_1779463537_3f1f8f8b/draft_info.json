        "texts": [
            {
                "id": "f5bc7ed6cc1d46c9a148599871801136",
                "content": "{\"styles\": [{\"fill\": {\"alpha\": 1.0, \"content\": {\"render_type\": \"solid\", \"solid\": {\"alpha\": 1.0, \"color\": [1.0, 0.0, 0.0]}}}, \"range\": [0, 51], \"size\": 8.0, \"bold\": false, \"italic\": false, \"underline\": false, \"strokes\": [{\"content\": {\"solid\": {\"alpha\": 0.5, \"color\": [0.0, 0.0, 0.0]}}, \"width\": 0.004}], \"font\": {\"id\": \"7290445778273702455\", \"path\": \"C:/文轩体.ttf\"}}], \"text\": \"哎哟，今天得跟大家说个事儿...就是那个U17亚洲杯决赛，中国男足和日本队的比赛，结果真让人大吃一惊！\"}",
                "typesetting": 0,
                "alignment": 1,
                "letter_spacing": 0.0,
                "line_spacing": 0.02,
                "line_feed": 1,
                "line_max_width": 0.82,
                "force_apply_line_max_width": false,
                "check_flag": 15,
                "type": "text",
                "fixed_width": -1,
                "fixed_height": -1
            },
            {
                "id": "7324900ce74a4e1b905a54809a743f51",
                "content": "{\"styles\": [{\"fill\": {\"alpha\": 1.0, \"content\": {\"render_type\": \"solid\", \"solid\": {\"alpha\": 1.0, \"color\": [1.0, 0.0, 0.0]}}}, \"range\": [0, 35], \"size\": 8.0, \"bold\": false, \"italic\": false, \"underline\": false, \"strokes\": [{\"content\": {\"solid\": {\"alpha\": 0.5, \"color\": [0.0, 0.0, 0.0]}}, \"width\": 0.004}], \"font\": {\"id\": \"7290445778273702455\", \"path\": \"C:/文轩体.ttf\"}}], \"text\": \"1. 比赛快到85分钟了，中国男足还落后人家一球，心都提到嗓子眼儿了。\"}",
                "typesetting": 0,
                "alignment": 1,
                "letter_spacing": 0.0,
                "line_spacing": 0.02,
                "line_feed": 1,
                "line_max_width": 0.82,
                "force_apply_line_max_width": false,
                "check_flag": 15,
                "type": "text",
                "fixed_width": -1,
                "fixed_height": -1
            },
            {
                "id": "cd9854b9b05444128daa3649a4ebd76e",
                "content": "{\"styles\": [{\"fill\": {\"alpha\": 1.0, \"content\": {\"render_type\": \"solid\", \"solid\": {\"alpha\": 1.0, \"color\": [1.0, 0.0, 0.0]}}}, \"range\": [0, 26], \"size\": 8.0, \"bold\": false, \"italic\": false, \"underline\": false, \"strokes\": [{\"content\": {\"solid\": {\"alpha\": 0.5, \"color\": [0.0, 0.0, 0.0]}}, \"width\": 0.004}], \"font\": {\"id\": \"7290445778273702455\", \"path\": \"C:/文轩体.ttf\"}}], \"text\": \"2. 突然，队长来了一脚世界波，哎呀妈呀，太神奇了！\"}",
                "typesetting": 0,
                "alignment": 1,
                "letter_spacing": 0.0,
                "line_spacing": 0.02,
                "line_feed": 1,
                "line_max_width": 0.82,
                "force_apply_line_max_width": false,
                "check_flag": 15,
                "type": "text",
                "fixed_width": -1,
                "fixed_height": -1
            },
            {
                "id": "324633c85d714d04baee71e9571dcbf2",
                "content": "{\"styles\": [{\"fill\": {\"alpha\": 1.0, \"content\": {\"render_type\": \"solid\", \"solid\": {\"alpha\": 1.0, \"color\": [1.0, 0.0, 0.0]}}}, \"range\": [0, 31], \"size\": 8.0, \"bold\": false, \"italic\": false, \"underline\": false, \"strokes\": [{\"content\": {\"solid\": {\"alpha\": 0.5, \"color\": [0.0, 0.0, 0.0]}}, \"width\": 0.004}], \"font\": {\"id\": \"7290445778273702455\", \"path\": \"C:/文轩体.ttf\"}}], \"text\": \"3. 比分瞬间变成1比1，全场的观众都沸腾了，那场面，太嗨了！\"}",
                "typesetting": 0,
                "alignment": 1,
                "letter_spacing": 0.0,
                "line_spacing": 0.02,
                "line_feed": 1,
                "line_max_width": 0.82,
                "force_apply_line_max_width": false,
                "check_flag": 15,
                "type": "text",
                "fixed_width": -1,
                "fixed_height": -1
            },
            {
                "id": "6d3754f1e56540c7b572641aa7159ce5",
                "content": "{\"styles\": [{\"fill\": {\"alpha\": 1.0, \"content\": {\"render_type\": \"solid\", \"solid\": {\"alpha\": 1.0, \"color\": [1.0, 0.0, 0.0]}}}, \"range\": [0, 29], \"size\": 8.0, \"bold\": false, \"italic\": false, \"underline\": false, \"strokes\": [{\"content\": {\"solid\": {\"alpha\": 0.5, \"color\": [0.0, 0.0, 0.0]}}, \"width\": 0.004}], \"font\": {\"id\": \"7290445778273702455\", \"path\": \"C:/文轩体.ttf\"}}], \"text\": \"4. 加时赛开始了，日本队又一度领先，感觉咱们这回要输了。\"}",
                "typesetting": 0,
                "alignment": 1,
                "letter_spacing": 0.0,
                "line_spacing": 0.02,
                "line_feed": 1,
                "line_max_width": 0.82,
                "force_apply_line_max_width": false,
                "check_flag": 15,
                "type": "text",
                "fixed_width": -1,
                "fixed_height": -1
            },
            {
                "id": "f69df11066ed4560ad590e4ffdd3e57e",
                "content": "{\"styles\": [{\"fill\": {\"alpha\": 1.0, \"content\": {\"render_type\": \"solid\", \"solid\": {\"alpha\": 1.0, \"color\": [1.0, 0.0, 0.0]}}}, \"range\": [0, 37], \"size\": 8.0, \"bold\": false, \"italic\": false, \"underline\": false, \"strokes\": [{\"content\": {\"solid\": {\"alpha\": 0.5, \"color\": [0.0, 0.0, 0.0]}}, \"width\": 0.004}], \"font\": {\"id\": \"7290445778273702455\", \"path\": \"C:/文轩体.ttf\"}}], \"text\": \"5. 最后，中国男足硬是靠着点球大战，总比分4比3逆袭夺冠了，太不容易了！\"}",
                "typesetting": 0,
                "alignment": 1,
                "letter_spacing": 0.0,
                "line_spacing": 0.02,
                "line_feed": 1,
                "line_max_width": 0.82,
                "force_apply_line_max_width": false,
                "check_flag": 15,
                "type": "text",
                "fixed_width": -1,
                "fixed_height": -1
            },
            {
                "id": "e721a211d9b948dcaa3ae24daac0bf9e",
                "content": "{\"styles\": [{\"fill\": {\"alpha\": 1.0, \"content\": {\"render_type\": \"solid\", \"solid\": {\"alpha\": 1.0, \"color\": [1.0, 0.0, 0.0]}}}, \"range\": [0, 45], \"size\": 8.0, \"bold\": false, \"italic\": false, \"underline\": false, \"strokes\": [{\"content\": {\"solid\": {\"alpha\": 0.5, \"color\": [0.0, 0.0, 0.0]}}, \"width\": 0.004}], \"font\": {\"id\": \"7290445778273702455\", \"path\": \"C:/文轩体.ttf\"}}], \"text\": \"这届U17亚洲杯，你更支持哪个队？是咱们的中国男足还是日本队？快在评论区告诉我你的选择吧！\"}",
                "typesetting": 0,
                "alignment": 1,
                "letter_spacing": 0.0,
